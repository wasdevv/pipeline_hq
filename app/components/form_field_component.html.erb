<div>
  <div class="flex items-center justify-between">
    <% if @form %>
      <%= @form.label @name, @label, class: "block text-sm font-medium" %>
    <% else %>
      <%= label_tag @name, @label, class: "block text-sm font-medium" %>
    <% end %>
    <% if @action_label && @action_path %>
      <%= link_to @action_label, @action_path, class: "text-xs text-indigo-600 hover:underline dark:text-indigo-400" %>
    <% end %>
  </div>

  <% if @form %>
    <%= @form.public_send(:"#{@type}_field", @name, input_attrs) %>
  <% else %>
    <% helper = case @type
                when :email    then :email_field_tag
                when :password then :password_field_tag
                else                :text_field_tag
                end %>
    <%= send(helper, @name, @value, input_attrs) %>
  <% end %>

  <% if @hint.present? %>
    <p class="mt-1 text-xs text-zinc-500 dark:text-zinc-400"><%= @hint %></p>
  <% end %>
</div>
