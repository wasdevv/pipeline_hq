<header class="sticky top-0 z-40 border-b border-zinc-200 bg-white/80 backdrop-blur dark:border-zinc-800 dark:bg-zinc-950/80">
  <div class="mx-auto flex h-14 max-w-7xl items-center justify-between gap-3 px-4 sm:px-6 lg:px-8">
    <div class="flex items-center gap-3">
      <%= link_to root_path, class: "flex items-center gap-2 text-sm font-semibold tracking-tight text-zinc-900 dark:text-zinc-100" do %>
        <svg viewBox="0 0 24 24" class="size-5 text-indigo-600 dark:text-indigo-400" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M4 6h16M4 12h10M4 18h6" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span class="hidden sm:inline">PipelineHQ</span>
      <% end %>

      <div class="hidden h-5 w-px bg-zinc-200 dark:bg-zinc-800 sm:block"></div>

      <%= render WorkspaceSwitcherComponent.new(current_user: @current_user, current_workspace: @current_workspace) %>
    </div>

    <div class="flex items-center gap-2">
      <div data-controller="theme">
        <button type="button" data-action="theme#toggle"
                aria-label="Alternar tema"
                class="inline-flex size-9 items-center justify-center rounded-full border border-zinc-200 bg-white/80 text-zinc-700 shadow-sm backdrop-blur transition hover:bg-white dark:border-zinc-800 dark:bg-zinc-900/80 dark:text-zinc-300 dark:hover:bg-zinc-900">
          <svg data-theme-target="sun" class="hidden size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="4"></circle>
            <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"></path>
          </svg>
          <svg data-theme-target="moon" class="hidden size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
          </svg>
        </button>
      </div>

      <div class="relative"
           data-controller="dropdown"
           data-action="keydown->dropdown#keydown"
           aria-haspopup="true">
        <button type="button"
                data-action="click->dropdown#toggle"
                class="inline-flex items-center gap-2 rounded-full border border-zinc-200 bg-white/80 py-1 pl-1 pr-3 text-sm text-zinc-700 shadow-sm backdrop-blur transition hover:bg-white dark:border-zinc-800 dark:bg-zinc-900/80 dark:text-zinc-200 dark:hover:bg-zinc-900"
                aria-label="Menu da conta">
          <span class="inline-flex size-7 items-center justify-center rounded-full bg-indigo-600 text-xs font-semibold text-white">
            <%= user_initials %>
          </span>
          <span class="hidden text-sm font-medium sm:inline"><%= first_name %></span>
          <svg class="size-3.5 text-zinc-400" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path d="M4.5 6L8 9.5 11.5 6" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>

        <div data-dropdown-target="menu"
             hidden
             role="menu"
             class="absolute right-0 top-full z-50 mt-2 w-56 rounded-lg border border-zinc-200 bg-white py-1 shadow-md dark:border-zinc-800 dark:bg-zinc-900">
          <div class="border-b border-zinc-100 px-3 py-2 dark:border-zinc-800">
            <p class="text-sm font-medium text-zinc-900 dark:text-zinc-100"><%= @current_user.name %></p>
            <p class="truncate text-xs text-zinc-500 dark:text-zinc-400"><%= @current_user.email_address %></p>
          </div>
          <%= link_to "Sessões ativas",
                sessions_management_index_path,
                class: "block px-3 py-2 text-sm text-zinc-700 hover:bg-zinc-50 dark:text-zinc-300 dark:hover:bg-zinc-800",
                role: "menuitem" %>
          <%= link_to "Autenticação 2FA",
                two_factor_path,
                class: "block px-3 py-2 text-sm text-zinc-700 hover:bg-zinc-50 dark:text-zinc-300 dark:hover:bg-zinc-800",
                role: "menuitem" %>
          <%= link_to "Auditoria do workspace",
                domain_events_path,
                class: "block px-3 py-2 text-sm text-zinc-700 hover:bg-zinc-50 dark:text-zinc-300 dark:hover:bg-zinc-800",
                role: "menuitem" %>
          <div class="my-1 border-t border-zinc-100 dark:border-zinc-800"></div>
          <%= button_to "Sair",
                session_path,
                method: :delete,
                class: "block w-full px-3 py-2 text-left text-sm text-rose-600 hover:bg-rose-50 dark:text-rose-400 dark:hover:bg-rose-950/30",
                role: "menuitem" %>
        </div>
      </div>
    </div>
  </div>
</header>
