<div class="flex min-h-screen items-center justify-center px-4 py-12 sm:px-6">
  <div class="w-full max-w-sm">
    <%= render AuthHeaderComponent.new(title: @title, subtitle: @subtitle) %>
    <%= content %>
    <% if @footer.present? %>
      <p class="mt-6 text-center text-sm text-zinc-500 dark:text-zinc-400"><%== @footer %></p>
    <% end %>
  </div>
</div>
