<% content_for :title, "Backup codes" %>
<div class="mx-auto max-w-2xl space-y-6 p-6">
  <header>
    <h1 class="text-2xl font-semibold tracking-tight">Backup codes</h1>
    <p class="mt-1 text-sm text-zinc-500 dark:text-zinc-400">Guarde em local seguro. Cada código só pode ser usado uma vez.</p>
  </header>

  <div class="grid grid-cols-2 gap-2 rounded-lg border border-zinc-200 bg-zinc-50 p-4 font-mono text-sm dark:border-zinc-800 dark:bg-zinc-900">
    <% @backup_codes.each do |code| %>
      <div><%= code %></div>
    <% end %>
  </div>

  <%= render ButtonSecondaryComponent.new(label: "Voltar", path: two_factor_path) %>
</div>
