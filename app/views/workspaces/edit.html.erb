<% content_for :title, "Editar #{@workspace.name} — PipelineHQ" %>

<div class="mx-auto max-w-xl space-y-6 p-6">
  <header>
    <h1 class="text-2xl font-semibold tracking-tight">Editar workspace</h1>
    <p class="mt-1 text-sm text-zinc-500 dark:text-zinc-400">
      Altere o nome do workspace. O slug é gerado automaticamente.
    </p>
  </header>

  <%= form_with model: @workspace, url: workspace_path(@workspace), method: :patch do |f| %>
    <div class="space-y-5">
      <%= render FormFieldComponent.new(
            name: :name,
            label: "Nome do workspace",
            form: f,
            autofocus: true,
            required: true,
            autocomplete: "organization") %>

      <div class="rounded-md border border-zinc-100 bg-zinc-50 px-3 py-2 dark:border-zinc-800 dark:bg-zinc-900">
        <p class="text-xs text-zinc-500 dark:text-zinc-400">
          Slug atual: <code class="font-mono"><%= @workspace.slug %></code> — atualizado automaticamente ao salvar.
        </p>
      </div>

      <% if @workspace.errors.any? %>
        <ul class="rounded-md border border-rose-200 bg-rose-50 px-3 py-2 text-sm text-rose-800 dark:border-rose-900 dark:bg-rose-950 dark:text-rose-200"
            role="alert"
            aria-live="assertive">
          <% @workspace.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      <% end %>

      <div class="flex items-center gap-3">
        <%= render ButtonPrimaryComponent.new(label: "Salvar alterações", form: f) %>
        <%= link_to "Cancelar", workspace_path(@workspace),
              class: "text-sm text-zinc-500 hover:text-zinc-700 dark:text-zinc-400 dark:hover:text-zinc-200" %>
      </div>
    </div>
  <% end %>
</div>
