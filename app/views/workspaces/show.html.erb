<% content_for :title, "#{@workspace.name} — PipelineHQ" %>

<div class="mx-auto max-w-3xl space-y-6 p-6">
  <header class="flex flex-wrap items-start justify-between gap-4">
    <div>
      <h1 class="text-2xl font-semibold tracking-tight"><%= @workspace.name %></h1>
      <p class="mt-0.5 font-mono text-sm text-zinc-400 dark:text-zinc-500">/<%= @workspace.slug %></p>
    </div>
    <%= link_to "Editar", edit_workspace_path(@workspace),
          class: "rounded-md border border-zinc-300 px-3 py-1.5 text-sm font-medium hover:bg-zinc-50 dark:border-zinc-700 dark:hover:bg-zinc-800" %>
  </header>

  <nav class="border-b border-zinc-200 dark:border-zinc-800" aria-label="Abas do workspace">
    <ul class="-mb-px flex gap-4 text-sm font-medium" role="tablist">
      <li>
        <%= link_to "Visão geral", workspace_path(@workspace),
              class: "inline-block border-b-2 border-indigo-600 pb-3 text-indigo-600 dark:border-indigo-400 dark:text-indigo-400",
              aria: { current: "page" } %>
      </li>
      <li>
        <%= link_to "Membros", workspace_memberships_path(@workspace),
              class: "inline-block border-b-2 border-transparent pb-3 text-zinc-500 transition hover:border-zinc-400 hover:text-zinc-700 dark:text-zinc-400 dark:hover:text-zinc-200" %>
      </li>
    </ul>
  </nav>

  <section class="grid gap-4 sm:grid-cols-3">
    <div class="rounded-lg border border-zinc-200 bg-white p-4 dark:border-zinc-800 dark:bg-zinc-900">
      <p class="text-xs font-medium uppercase tracking-wide text-zinc-500 dark:text-zinc-400">Membros</p>
      <p class="mt-1 text-2xl font-semibold"><%= @workspace.workspace_memberships.size %></p>
    </div>
    <div class="rounded-lg border border-zinc-200 bg-white p-4 dark:border-zinc-800 dark:bg-zinc-900">
      <p class="text-xs font-medium uppercase tracking-wide text-zinc-500 dark:text-zinc-400">Negócios</p>
      <p class="mt-1 text-2xl font-semibold"><%= @workspace.deals.size %></p>
    </div>
    <div class="rounded-lg border border-zinc-200 bg-white p-4 dark:border-zinc-800 dark:bg-zinc-900">
      <p class="text-xs font-medium uppercase tracking-wide text-zinc-500 dark:text-zinc-400">Contas</p>
      <p class="mt-1 text-2xl font-semibold"><%= @workspace.accounts.size %></p>
    </div>
  </section>

  <section>
    <h2 class="mb-3 text-sm font-semibold uppercase tracking-wide text-zinc-500 dark:text-zinc-400">
      Informações
    </h2>
    <dl class="divide-y divide-zinc-100 rounded-lg border border-zinc-200 bg-white dark:divide-zinc-800 dark:border-zinc-800 dark:bg-zinc-900">
      <div class="flex items-center justify-between px-4 py-3 text-sm">
        <dt class="font-medium text-zinc-500 dark:text-zinc-400">Proprietário</dt>
        <dd><%= @workspace.owner.name %></dd>
      </div>
      <div class="flex items-center justify-between px-4 py-3 text-sm">
        <dt class="font-medium text-zinc-500 dark:text-zinc-400">Criado em</dt>
        <dd><%= l(@workspace.created_at, format: :long) %></dd>
      </div>
    </dl>
  </section>
</div>
