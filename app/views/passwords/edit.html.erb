<% content_for :title, "Definir nova senha" %>
<%= render AuthShellComponent.new(
      title: "Definir nova senha",
      subtitle: "Mínimo 12 caracteres, mistura de tipos."
    ) do %>
  <%= form_with url: password_path(params[:token]), method: :patch, local: true, class: "space-y-4" do |f| %>
    <%= render FormFieldComponent.new(name: :password, label: "Senha", type: :password,
          autocomplete: "new-password", required: true) %>
    <%= render FormFieldComponent.new(name: :password_confirmation, label: "Confirme a senha", type: :password,
          autocomplete: "new-password", required: true) %>
    <%= render ButtonPrimaryComponent.new(label: "Salvar nova senha") %>
  <% end %>
<% end %>
