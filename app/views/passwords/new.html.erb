<% content_for :title, "Esqueci minha senha" %>
<%= render AuthShellComponent.new(
      title: "Esqueci minha senha",
      subtitle: "Vamos enviar um link de redefinição.",
      footer: link_to("Voltar para login", new_session_path, class: "font-medium text-indigo-600 hover:underline dark:text-indigo-400")
    ) do %>
  <%= form_with url: passwords_path, local: true, class: "space-y-4" do |f| %>
    <%= render FormFieldComponent.new(name: :email_address, label: "Email", type: :email,
          autocomplete: "email", required: true) %>
    <%= render ButtonPrimaryComponent.new(label: "Enviar link") %>
  <% end %>
<% end %>
