<!DOCTYPE html>
<html lang="pt-BR" class="h-full">
  <head>
    <title><%= content_for(:title) || "PipelineHQ" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="PipelineHQ">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Anti-flash: aplica tema antes do CSS carregar %>
    <script>
      (function() {
        try {
          var stored = localStorage.getItem("theme");
          var systemDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
          var useDark = stored ? stored === "dark" : systemDark;
          if (useDark) document.documentElement.classList.add("dark");
        } catch (_) {}
      })();
    </script>

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-full bg-white text-zinc-900 antialiased dark:bg-zinc-950 dark:text-zinc-100">
    <% if authenticated? && current_user %>
      <%= render TopbarComponent.new(current_user: current_user, current_workspace: current_workspace) %>
    <% else %>
      <div class="fixed right-4 top-4 z-50" data-controller="theme">
        <button type="button" data-action="theme#toggle"
                aria-label="Alternar tema"
                class="rounded-full border border-zinc-200 bg-white/80 p-2 text-zinc-700 shadow-sm backdrop-blur transition hover:bg-white dark:border-zinc-800 dark:bg-zinc-900/80 dark:text-zinc-300 dark:hover:bg-zinc-900">
          <svg data-theme-target="sun" class="hidden size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="4"></circle>
            <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"></path>
          </svg>
          <svg data-theme-target="moon" class="hidden size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
          </svg>
        </button>
      </div>
    <% end %>

    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <%= render "shared/flash" %>
    </div>

    <%= yield %>
  </body>
</html>
