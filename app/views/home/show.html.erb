<% content_for :title, "Dashboard — PipelineHQ" %>
<div class="mx-auto max-w-5xl space-y-8 p-6">
  <header>
    <h1 class="text-2xl font-semibold tracking-tight">Bem-vindo, <%= current_user.name.split.first %></h1>
    <p class="mt-1 text-sm text-zinc-500 dark:text-zinc-400">PipelineHQ — seu CRM B2B.</p>
  </header>

  <section class="grid gap-4 sm:grid-cols-3">
    <%= render NavCardComponent.new(title: "Accounts", subtitle: "Empresas-cliente.", href: accounts_path) %>
    <%= render NavCardComponent.new(title: "Contacts", subtitle: "Pessoas dos clientes.", href: contacts_path) %>
    <%= render NavCardComponent.new(title: "Deals", subtitle: "Oportunidades em pipeline.", href: deals_path) %>
    <%= render NavCardComponent.new(title: "Auditoria", subtitle: "Registro de ações do workspace.", href: domain_events_path) %>
  </section>

  <section>
    <h2 class="mb-3 text-sm font-semibold uppercase tracking-wide text-zinc-500 dark:text-zinc-400">Atividade recente</h2>
    <ul class="divide-y divide-zinc-200 rounded-lg border border-zinc-200 dark:divide-zinc-800 dark:border-zinc-800">
      <% @auth_events.each do |e| %>
        <li class="flex items-center justify-between p-3 text-sm">
          <span class="font-mono"><%= e.kind %></span>
          <span class="text-zinc-500 dark:text-zinc-400"><%= e.created_at.to_fs(:short) %></span>
        </li>
      <% end %>
    </ul>
  </section>
</div>
