<div id="<%= dom_id activity %>" class="w-full sm:w-auto my-5 space-y-5">
  <div>
    <strong class="block font-medium mb-1">Deal:</strong>
    <%= activity.deal_id %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Kind:</strong>
    <%= activity.kind %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Subject:</strong>
    <%= activity.subject %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Body:</strong>
    <%= activity.body %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Occurred at:</strong>
    <%= activity.occurred_at %>
  </div>
</div>
