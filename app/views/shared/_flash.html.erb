<% if notice.present? %>
  <div role="status" aria-live="polite" class="mb-4 rounded-md border border-emerald-200 bg-emerald-50 px-3 py-2 text-sm text-emerald-900 dark:border-emerald-900 dark:bg-emerald-950 dark:text-emerald-100">
    <%= notice %>
  </div>
<% end %>
<% if alert.present? %>
  <div role="alert" aria-live="assertive" class="mb-4 rounded-md border border-rose-200 bg-rose-50 px-3 py-2 text-sm text-rose-900 dark:border-rose-900 dark:bg-rose-950 dark:text-rose-100">
    <%= alert %>
  </div>
<% end %>
