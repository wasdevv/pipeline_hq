<% content_for :title, t("domain_events.index.title") %>

<div class="mx-auto max-w-5xl space-y-6 p-6">
  <header class="flex flex-wrap items-center justify-between gap-4">
    <div>
      <h1 class="text-2xl font-semibold tracking-tight"><%= t("domain_events.index.title") %></h1>
      <p class="mt-1 text-sm text-zinc-500 dark:text-zinc-400"><%= t("domain_events.index.subtitle") %></p>
    </div>
    <%= link_to t("domain_events.index.back"), root_path,
        class: "text-sm font-medium text-zinc-500 hover:text-zinc-900 dark:hover:text-zinc-100 underline underline-offset-2" %>
  </header>

  <form class="flex items-center gap-3" method="get" action="<%= domain_events_path %>">
    <label for="kind_filter" class="text-sm font-medium text-zinc-700 dark:text-zinc-300">
      <%= t("domain_events.index.filter_label") %>
    </label>
    <select id="kind_filter" name="kind"
            onchange="this.form.submit()"
            class="rounded-md border border-zinc-300 bg-white px-3 py-1.5 text-sm shadow-sm dark:border-zinc-700 dark:bg-zinc-900 dark:text-zinc-100">
      <option value=""><%= t("domain_events.index.all_kinds") %></option>
      <% DomainEvent::KINDS.each do |kind| %>
        <option value="<%= kind %>" <%= "selected" if params[:kind] == kind %>>
          <%= t("domain_events.kinds.#{kind.tr(".", "_")}", default: kind) %>
        </option>
      <% end %>
    </select>
  </form>

  <% if @domain_events.any? %>
    <ul class="divide-y divide-zinc-200 rounded-lg border border-zinc-200 dark:divide-zinc-800 dark:border-zinc-800">
      <% @domain_events.each do |event| %>
        <li class="p-4 text-sm">
          <div class="flex flex-wrap items-start justify-between gap-2">
            <div class="space-y-1">
              <div class="flex items-center gap-2">
                <span class="inline-block rounded bg-zinc-100 px-2 py-0.5 font-mono text-xs text-zinc-700 dark:bg-zinc-800 dark:text-zinc-300">
                  <%= t("domain_events.kinds.#{event.kind.tr(".", "_")}", default: event.kind) %>
                </span>
                <span class="text-zinc-500 dark:text-zinc-400">
                  <%= t("domain_events.index.by_actor", actor: event.actor&.name || t("domain_events.index.system")) %>
                </span>
              </div>
              <% if event.subject.present? %>
                <p class="text-zinc-500 dark:text-zinc-400">
                  <%= t("domain_events.index.subject_label") %>:
                  <span class="text-zinc-700 dark:text-zinc-300"><%= event.subject.to_s %></span>
                </p>
              <% elsif event.subject_type.present? %>
                <p class="text-zinc-400 dark:text-zinc-600 italic text-xs">
                  <%= t("domain_events.index.subject_deleted", type: event.subject_type) %>
                </p>
              <% end %>
            </div>
            <time class="shrink-0 text-xs text-zinc-400 dark:text-zinc-600"
                  datetime="<%= event.created_at.iso8601 %>"
                  title="<%= l(event.created_at, format: :long) %>">
              <%= time_ago_in_words(event.created_at) %> <%= t("domain_events.index.ago") %>
            </time>
          </div>
          <% if event.metadata.present? %>
            <details class="mt-2">
              <summary class="cursor-pointer text-xs text-zinc-400 hover:text-zinc-600 dark:hover:text-zinc-300">
                <%= t("domain_events.index.show_metadata") %>
              </summary>
              <pre class="mt-1 overflow-x-auto rounded bg-zinc-50 p-2 text-xs text-zinc-600 dark:bg-zinc-900 dark:text-zinc-400"><%= JSON.pretty_generate(event.metadata) %></pre>
            </details>
          <% end %>
        </li>
      <% end %>
    </ul>

    <nav class="flex items-center justify-between pt-2 text-sm">
      <% if @current_page > 1 %>
        <%= link_to t("domain_events.index.previous"),
            domain_events_path(page: @current_page - 1, kind: params[:kind]),
            class: "font-medium text-zinc-700 hover:text-zinc-900 dark:text-zinc-300 dark:hover:text-zinc-100 underline underline-offset-2" %>
      <% else %>
        <span class="text-zinc-300 dark:text-zinc-700"><%= t("domain_events.index.previous") %></span>
      <% end %>

      <span class="text-zinc-500 dark:text-zinc-400">
        <%= t("domain_events.index.page_info", page: @current_page, total: @total_pages) %>
      </span>

      <% if @current_page < @total_pages %>
        <%= link_to t("domain_events.index.next"),
            domain_events_path(page: @current_page + 1, kind: params[:kind]),
            class: "font-medium text-zinc-700 hover:text-zinc-900 dark:text-zinc-300 dark:hover:text-zinc-100 underline underline-offset-2" %>
      <% else %>
        <span class="text-zinc-300 dark:text-zinc-700"><%= t("domain_events.index.next") %></span>
      <% end %>
    </nav>
  <% else %>
    <div class="rounded-lg border border-zinc-200 p-8 text-center text-sm text-zinc-500 dark:border-zinc-800 dark:text-zinc-400">
      <%= t("domain_events.index.empty") %>
    </div>
  <% end %>
</div>
